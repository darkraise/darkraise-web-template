{
  "name": "darkraise-web-template-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter darkraise-ui build",
    "dev": "pnpm --filter darkraise-ui dev",
    "dev:template": "pnpm --filter darkraise-web-template dev",
    "test": "pnpm --filter \"./packages/*\" test",
    "test:template": "pnpm --filter darkraise-web-template test",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx,css,json,md}\"",
    "typecheck": "pnpm -r typecheck",
    "storybook": "pnpm --filter darkraise-ui storybook",
    "publish:ui": "pnpm --filter darkraise-ui publish"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
