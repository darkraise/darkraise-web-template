{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "composite": true,
    "emitDeclarationOnly": true,
    "declaration": true,
    "strict": true
  },
  "include": [
    "vite.config.ts",
    "tailwind.config.ts",
    "eslint.config.js",
    "commitlint.config.ts",
    "vitest.config.ts",
    "playwright.config.ts"
  ]
}
